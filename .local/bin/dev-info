#!/bin/sh

CACHE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/fastfetch/dev-info"

# 1. check if cache exists. If yes, print and exit immediately.
if [ -f "$CACHE_FILE" ]; then
    cat "$CACHE_FILE"
    exit 0
fi

# 2. If no cache, run the heavy commands (only happens once)
dotnet_v=$(dotnet --version 2>/dev/null || echo "N/A")
node_v=$(node --version 2>/dev/null | sed 's/v//')

# Build the string
OUTPUT=$(printf "\e[0m.NET\e[0m %s / \e[33m\e[0m %s\e[0m" "$dotnet_v" "$node_v")

# 3. Save to cache and print
echo "$OUTPUT" > "$CACHE_FILE"
echo "$OUTPUT"
